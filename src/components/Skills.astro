---
const pipeline = [
  {
    stage: 'Plan & Code',
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
    tools: [
      { name: 'Python', img: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg' },
      { name: 'Go', img: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/go/go-original-wordmark.svg' },
      { name: 'Bash', img: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/bash/bash-original.svg', dark: true },
      { name: 'Jira', img: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/jira/jira-original.svg' },
    ],
  },
  {
    stage: 'Build & Test',
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72Z"/><path d="m14 7 3 3"/></svg>',
    tools: [
      { name: 'GitHub Actions', img: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/githubactions/githubactions-original.svg' },
      { name: 'GitLab CI', img: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/gitlab/gitlab-original.svg' },
      { name: 'Jenkins', img: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/jenkins/jenkins-original.svg' },
      { name: 'SonarQube', img: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/sonarqube/sonarqube-original.svg' },
    ],
  },
  {
    stage: 'Release & Deploy',
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>',
    tools: [
      { name: 'Terraform', img: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/terraform/terraform-original.svg' },
      { name: 'ArgoCD', img: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/argocd/argocd-original.svg' },
      { name: 'Helm', img: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/helm/helm-original.svg', dark: true },
      { name: 'AWS', img: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/amazonwebservices/amazonwebservices-plain-wordmark.svg', dark: true },
    ],
  },
  {
    stage: 'Operate & Monitor',
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>',
    tools: [
      { name: 'Docker', img: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/docker/docker-original.svg' },
      { name: 'Kubernetes', img: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/kubernetes/kubernetes-original.svg' },
      { name: 'Azure', img: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/azure/azure-original.svg' },
      { name: 'GCP', img: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/googlecloud/googlecloud-original.svg' },
    ],
  },
];

const certs = [
  { name: 'AWS Solutions Architect', level: 'Professional', logo: 'aws', color: '#FF9900' },
  { name: 'AWS DevOps Engineer', level: 'Professional', logo: 'aws', color: '#FF9900' },
  { name: 'AWS Developer', level: 'Associate', logo: 'aws', color: '#FF9900' },
  { name: 'GCP Cloud Developer', level: 'Professional', logo: 'gcp', color: '#4285F4' },
  { name: 'GCP Solutions Architect', level: 'Professional', logo: 'gcp', color: '#4285F4' },
  { name: 'MongoDB Developer', level: 'Associate', logo: 'mongodb', color: '#00ED64' },
  { name: 'Scrum Master II', level: 'PSM II', logo: 'scrum', color: '#009FDA' },
];
---

<section id="skills" class="section">
  <div class="container">
    <p class="section-label reveal">Skills & Certifications</p>
    <h2 class="section-title reveal stagger-1">Tools of the Trade</h2>

    <div class="tabs reveal stagger-2">
      <button class="tab active" data-tab="pipeline">Pipeline</button>
      <button class="tab" data-tab="certs">Certifications</button>
    </div>

    <!-- Pipeline tab -->
    <div class="tab-content active" id="tab-pipeline">
      <div class="pipeline">
        {pipeline.map((s, i) => (
          <Fragment>
            <div class="pipe-stage" data-stage={i}>
              <div class="pipe-header">
                <span class="pipe-icon" set:html={s.icon} />
                <span class="pipe-name">{s.stage}</span>
              </div>
              <div class="pipe-tools">
                {s.tools.map((t) => (
                  <div class="pipe-tool" title={t.name}>
                    <img src={t.img} alt={t.name} width="24" height="24" loading="lazy" class={t.dark ? 'dark-icon' : ''} />
                    <span>{t.name}</span>
                  </div>
                ))}
              </div>
            </div>
            {i < pipeline.length - 1 && (
              <div class="pipe-arrow" aria-hidden="true" data-arrow={i}>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              </div>
            )}
          </Fragment>
        ))}
      </div>
    </div>

    <!-- Certs tab -->
    <div class="tab-content" id="tab-certs">
      <div class="cert-grid">
        {certs.map((cert) => (
          <div class="card cert-card">
            <div class="cert-logo">
              {cert.logo === 'aws' && <svg viewBox="0 0 64 64" width="36" height="36" fill="none"><path d="M18.1 28.2c0 .7.1 1.3.2 1.7.2.5.4.9.6 1.5.1.2.2.4.2.5 0 .2-.1.4-.4.7l-1.3.9c-.2.1-.4.2-.5.2-.2 0-.4-.1-.6-.3-.3-.3-.5-.6-.7-1-.2-.4-.4-.8-.6-1.3-1.6 1.9-3.6 2.8-6 2.8-1.7 0-3.1-.5-4.1-1.5s-1.5-2.3-1.5-3.9c0-1.7.6-3.1 1.9-4.2 1.3-1 2.9-1.6 5.1-1.6.7 0 1.4.1 2.2.2.8.1 1.6.3 2.4.5v-1.5c0-1.5-.3-2.6-1-3.3-.6-.7-1.7-1-3.3-1-.7 0-1.4.1-2.2.3-.8.2-1.5.4-2.2.8-.3.2-.6.3-.7.3-.2 0-.3-.1-.3-.4v-1.1c0-.3 0-.5.1-.6.1-.1.3-.3.6-.4.7-.4 1.6-.7 2.5-.9.9-.3 1.9-.4 3-.4 2.3 0 3.9.5 5 1.6 1 1.1 1.5 2.7 1.5 4.9v6.4zm-8.3 3.1c.7 0 1.4-.1 2.1-.4.8-.3 1.4-.7 2-1.3.3-.4.6-.8.7-1.3.1-.5.2-1.1.2-1.8v-.9c-.6-.2-1.2-.3-1.9-.4-.7-.1-1.3-.1-2-.1-1.4 0-2.4.3-3 .8-.7.6-1 1.3-1 2.3 0 .9.2 1.6.7 2.1.5.6 1.2.8 2.1.8zm16.4 2.2c-.3 0-.5 0-.6-.2-.2-.1-.3-.4-.4-.8L20.8 17c-.1-.4-.2-.7-.2-.8 0-.3.2-.5.5-.5h2c.3 0 .5.1.6.2.2.1.3.4.4.8l3 12 2.8-12c.1-.4.2-.7.4-.8.2-.1.4-.2.7-.2h1.6c.3 0 .5.1.7.2.2.1.3.4.4.8l2.8 12.2 3.1-12.2c.1-.4.2-.7.4-.8.2-.1.4-.2.6-.2h1.9c.3 0 .5.2.5.5 0 .1 0 .2-.1.4 0 .1-.1.3-.2.5l-4.3 15.5c-.1.4-.2.7-.4.8-.2.1-.4.2-.6.2h-1.7c-.3 0-.5-.1-.7-.2-.2-.1-.3-.4-.4-.8l-2.8-11.7-2.7 11.7c-.1.4-.2.7-.4.8-.2.1-.4.2-.7.2h-1.7zm26.2.6c-1.1 0-2.1-.1-3.1-.4-1-.3-1.8-.6-2.3-1-.3-.2-.5-.4-.6-.6 0-.2-.1-.3-.1-.5v-1.1c0-.3.1-.5.3-.5.1 0 .2 0 .3.1.1.1.3.1.5.2.7.3 1.4.6 2.2.8.8.2 1.5.3 2.3.3 1.2 0 2.2-.2 2.8-.7.6-.5 1-1.1 1-2 0-.6-.2-1.1-.5-1.4-.4-.4-1-.7-2-1l-2.8-.9c-1.4-.5-2.5-1.1-3.1-2-.6-.8-1-1.8-1-2.9 0-.8.2-1.6.5-2.2.4-.7.8-1.2 1.4-1.7.6-.5 1.3-.8 2.1-1.1.8-.3 1.7-.4 2.6-.4.5 0 .9 0 1.4.1.5.1.9.2 1.4.3.4.1.8.3 1.2.4.4.2.7.3.9.5.3.2.5.3.6.5.1.2.2.4.2.7v1c0 .3-.1.5-.3.5-.1 0-.3-.1-.6-.2-1.3-.6-2.7-.9-4.2-.9-1.1 0-2 .2-2.6.6-.6.4-.9 1-.9 1.8 0 .6.2 1.1.6 1.5.4.4 1.1.7 2.1 1.1l2.7.9c1.4.5 2.4 1.1 3 1.9.6.8.9 1.7.9 2.8 0 .9-.2 1.6-.5 2.3-.4.7-.8 1.3-1.5 1.7-.6.5-1.3.8-2.2 1.1-.9.3-1.8.4-2.8.4z" fill="#FF9900"/><path d="M50.4 41.5c-5.8 4.3-14.3 6.6-21.6 6.6-10.2 0-19.4-3.8-26.4-10.1-.5-.5-.1-1.2.6-.8 7.5 4.4 16.8 7 26.4 7 6.5 0 13.6-1.3 20.1-4.1 1-.4 1.8.7.9 1.4z" fill="#FF9900"/><path d="M52.7 38.9c-.7-.9-4.8-.4-6.6-.2-.6.1-.6-.4-.1-.8 3.2-2.3 8.5-1.6 9.1-.9.6.8-.2 6.2-3.2 8.8-.5.4-.9.2-.7-.3.7-1.7 2.2-5.6 1.5-6.6z" fill="#FF9900"/></svg>}
              {cert.logo === 'gcp' && <svg viewBox="0 0 64 64" width="36" height="36" fill="none"><path d="M40.6 22.8h1.6l4.6-4.6.2-2C42.8 12.4 37.6 10 32 10c-8.2 0-15.2 4.8-18.4 11.8l1.7.2 9.2-1.5.7-.7c2.5-2.7 6.2-4.2 9.8-3.6 2.6.4 4.8 1.7 6.4 3.6l-.8 3z" fill="#EA4335"/><path d="M50.8 21.8c-1.2-3.6-3.4-6.8-6.2-9.2l-6.4 6.4c2.4 1.9 3.9 4.8 4 8v1c2.8 0 5 2.2 5 5s-2.2 5-5 5H32l-1 1v6l1 1h10.2c7.4 0 13.6-5.8 13.8-13.2.2-4.6-2-9-5.2-12z" fill="#4285F4"/><path d="M21.8 46h10.2v-8H21.8c-.7 0-1.4-.2-2-.4l-1.4.4-4.6 4.6-.4 1.4c2.2 1.4 4.8 2 7.4 2h1z" fill="#34A853"/><path d="M21.8 19.6C14.4 19.8 8.4 26 8.2 33.4c-.2 4.6 2 8.8 5.2 11.6l6.4-6.4c-2-1-3.4-3-3.4-5.4 0-3.2 2.6-5.8 5.8-5.8.8 0 1.6.2 2.4.4l6.4-6.4c-2.6-1.4-5.6-2-8.6-1.8h-.6z" fill="#FBBC05"/></svg>}
              {cert.logo === 'mongodb' && <svg viewBox="0 0 64 64" width="36" height="36" fill="none"><path d="M33.3 8.4c-.4-.8-.8-1.2-.9-1.8-.4-.4-.4-.8-.8-1.2 0 0 0 .4-.4.4-.4.8-.4 1.6-.8 2-.8 1.6-2 2.8-3.2 4.4-3.6 4-6 8.8-6.4 14.4-.4 3.2.4 6 1.6 8.8 2 4.4 5.2 7.6 9.2 10l.8.8c0-.4.4-.8.4-1.2l.4-3.2c0-.4 0-.4-.4-.8-1.2-.8-2-1.6-2.8-2.8-1.6-2-2.4-4.4-2.4-7.2 0-2.8.8-5.2 2.4-7.2 1.2-1.6 2.8-2.8 4.4-4 0 0 .4-.4.4-.8-.4-2.8-.8-5.6-1.2-8.4 0-.8 0-1.6-.4-2.4l.1.2z" fill="#00ED64"/><path d="M34.1 42.8c0-.4 0-.4-.4-.8-.8-.4-1.2-1.2-1.2-2v-.4c.4.4.8.4.8.8.8.4 1.2.4 2 .4 0 0 .4 0 .4.4-.4 2-.4 4-.8 6l-.4 1.2c0 .4 0 .4-.4.4v-6z" fill="#B8C4C2"/><path d="M34.5 39.6c0-.4-.4-.8-.8-1.2-.4 0-.4-.4-.4-.4.4 0 .4-.4.8-.4 1.2-.4 2-1.2 2.8-2.4 1.6-2.4 2-5.2 1.6-8-.4-2.4-1.2-4.4-2.8-6.4-1.2-1.6-2.8-3.2-4-4.8-.4-.4-.8-1.2-1.2-1.6 0 2.4-.4 4.4-.8 6.8 0 .4 0 .8-.4 1.2 0 .4.4.4.4.8 2 2 3.6 4 4.4 6.8.4 1.6.8 3.2.4 4.8-.4 2-1.2 3.6-2.8 4.8-.4.4-.4.4-.4.8 0 .8.4 2 1.2 2.4.4.4.4.4.4.8v.4c.4-1.2.8-2.4 1.2-3.6.4-.4.4-.4.4-.8z" fill="#12924F"/></svg>}
              {cert.logo === 'scrum' && <svg viewBox="0 0 64 64" width="36" height="36" fill="none"><circle cx="32" cy="32" r="22" stroke="#009FDA" stroke-width="3" fill="none"/><circle cx="32" cy="32" r="8" fill="#009FDA"/><circle cx="32" cy="14" r="4" fill="#009FDA"/><circle cx="47.6" cy="41" r="4" fill="#009FDA"/><circle cx="16.4" cy="41" r="4" fill="#009FDA"/><line x1="32" y1="18" x2="32" y2="24" stroke="#009FDA" stroke-width="2"/><line x1="44.4" y1="39" x2="39" y2="35" stroke="#009FDA" stroke-width="2"/><line x1="19.6" y1="39" x2="25" y2="35" stroke="#009FDA" stroke-width="2"/></svg>}
            </div>
            <div class="cert-info">
              <p class="cert-name">{cert.name}</p>
              <span class="cert-level" style={`color: ${cert.color}`}>{cert.level}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Tabs */
  .tabs {
    display: flex;
    gap: 4px;
    margin-top: 24px;
    margin-bottom: 32px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 4px;
    width: fit-content;
  }

  .tab {
    padding: 8px 20px;
    font-size: 0.8rem;
    font-weight: 500;
    font-family: var(--font);
    color: var(--text-muted);
    background: none;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .tab:hover {
    color: var(--text);
  }

  .tab.active {
    background: rgba(20, 184, 166, 0.15);
    color: var(--accent);
  }

  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  /* Pipeline */
  .pipeline {
    display: flex;
    align-items: flex-start;
    gap: 0;
    overflow-x: auto;
    padding-bottom: 8px;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.1) transparent;
  }

  .pipe-stage {
    flex: 1;
    min-width: 140px;
    text-align: center;
    position: relative;
  }

  .pipe-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    margin-bottom: 16px;
  }

  .pipe-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(20, 184, 166, 0.1);
    border: 1px solid rgba(20, 184, 166, 0.2);
    color: #14b8a6;
    transition: all 0.3s;
  }

  .pipe-stage:hover .pipe-icon {
    background: rgba(20, 184, 166, 0.2);
    border-color: rgba(20, 184, 166, 0.4);
    box-shadow: 0 4px 20px rgba(20, 184, 166, 0.15);
  }

  .pipe-name {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #a1a1aa;
    transition: color 0.3s;
  }

  .pipe-stage:hover .pipe-name {
    color: #14b8a6;
  }

  .pipe-arrow {
    display: flex;
    align-items: center;
    padding-top: 10px;
    color: rgba(255, 255, 255, 0.15);
    flex-shrink: 0;
  }

  .pipe-arrow svg {
    width: 16px;
    height: 16px;
  }

  .pipe-tools {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .pipe-tool {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 5px 10px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.2s;
    width: 100%;
    max-width: 150px;
  }

  .pipe-tool:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .pipe-tool img {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    border-radius: 4px;
  }

  .pipe-tool img.dark-icon {
    filter: brightness(0) invert(1);
    opacity: 0.85;
  }

  .pipe-tool span {
    font-size: 0.68rem;
    color: #a1a1aa;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Cycling glow — 4 stages, 2s each = 8s */
  @keyframes icon-glow {
    0%, 20% {
      background: rgba(20, 184, 166, 0.25);
      border-color: rgba(20, 184, 166, 0.5);
      box-shadow: 0 0 16px rgba(20, 184, 166, 0.2);
    }
    25%, 100% {
      background: rgba(20, 184, 166, 0.1);
      border-color: rgba(20, 184, 166, 0.2);
      box-shadow: none;
    }
  }

  .pipe-stage[data-stage="0"] .pipe-icon { animation: icon-glow 8s 0s infinite; }
  .pipe-stage[data-stage="1"] .pipe-icon { animation: icon-glow 8s 2s infinite; }
  .pipe-stage[data-stage="2"] .pipe-icon { animation: icon-glow 8s 4s infinite; }
  .pipe-stage[data-stage="3"] .pipe-icon { animation: icon-glow 8s 6s infinite; }

  @keyframes arrow-pulse {
    0%, 20% { color: rgba(20, 184, 166, 0.6); }
    25%, 100% { color: rgba(255, 255, 255, 0.15); }
  }

  .pipe-arrow[data-arrow="0"] { animation: arrow-pulse 8s 1s infinite; }
  .pipe-arrow[data-arrow="1"] { animation: arrow-pulse 8s 3s infinite; }
  .pipe-arrow[data-arrow="2"] { animation: arrow-pulse 8s 5s infinite; }

  /* Cert cards */
  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 12px;
  }

  .cert-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 18px;
  }

  .cert-logo {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .cert-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cert-name {
    font-size: 0.85rem;
    color: #e4e4e7;
    font-weight: 500;
  }

  .cert-level {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  @media (max-width: 900px) {
    .pipeline {
      flex-wrap: nowrap;
    }
    .pipe-stage {
      min-width: 120px;
    }
  }

  @media (max-width: 600px) {
    .cert-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-tab]').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('[data-tab]').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        tab.classList.add('active');
        const target = document.getElementById('tab-' + tab.dataset.tab);
        if (target) target.classList.add('active');
      });
    });
  });
</script>
